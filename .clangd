CompileFlags:
  Add: 
    - "-Wall"
    - "-Wextra"

If:
  Platform: windows 
CompileFlags:
  Add:
    - "--target=x86_64-pc-windows-msvc"
    - "--driver-mode=cl"
    - "-fms-extensions"
    - "-D_CRT_SECURE_NO_WARNINGS"

  CompilationDatabase: "build/windows-debug"

If:
  Platform: linux
CompileFlags:
  Add:
    - "--target=x86_64-pc-linux-gnu"

  CompilationDatabase: "build/linux-debug"