{
    "version": 8,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_C_FLAGS": "-finput-charset=UTF-8 -fexec-charset=UTF-8 -Wall -Wextra",
                "CMAKE_CXX_FLAGS": "-finput-charset=UTF-8 -fexec-charset=UTF-8 -Wall -Wextra"
            }
        },
        {
            "name": "debug",
            "inherits": "base",
            "displayName": "GCC Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "inherits": "base",
            "displayName": "GCC Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_FLAGS_RELEASE": "-O2 -DNDEBUG -ffunction-sections -fdata-sections",
                "CMAKE_CXX_FLAGS_RELEASE": "-O2 -DNDEBUG -ffunction-sections -fdata-sections",
                "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-Wl,--gc-sections -s",
                "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "-Wl,--gc-sections -s"
            }
        }
    ]
}